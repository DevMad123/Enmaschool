# ===== .env.example =====
# Enma School — SaaS EdTech Multi-Tenant
# Configuration complète documentée

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="Enma School"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://enmaschool.test
APP_PORT=8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

# =============================================================================
# SÉCURITÉ
# =============================================================================
BCRYPT_ROUNDS=12

# =============================================================================
# LOGGING
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# BASE DE DONNÉES — PostgreSQL 18
# =============================================================================
# Connexion centrale (schema public)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=enmaschool
DB_USERNAME=postgres
DB_PASSWORD=

# =============================================================================
# MULTI-TENANCY (stancl/tenancy)
# =============================================================================
# Le domaine central — les sous-domaines servent de résolution tenant
# Ex: {slug}.enmaschool.test → résolu automatiquement
TENANCY_CENTRAL_DOMAINS=enmaschool.test,localhost

# =============================================================================
# SESSION
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.enmaschool.test

# =============================================================================
# SANCTUM — Authentification API (SPA + Token)
# =============================================================================
SANCTUM_STATEFUL_DOMAINS=enmaschool.test,*.enmaschool.test,localhost

# =============================================================================
# CACHE & QUEUE
# =============================================================================
CACHE_STORE=redis
CACHE_PREFIX=enmaschool

QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local

# =============================================================================
# REDIS
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# BROADCAST — Laravel Reverb (WebSocket)
# =============================================================================
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=enmaschool
REVERB_APP_KEY=enmaschool-key
REVERB_APP_SECRET=enmaschool-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# =============================================================================
# MAIL
# =============================================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@enmaschool.test"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# HORIZON (Queue Dashboard)
# =============================================================================
HORIZON_PREFIX=enmaschool-horizon:

# =============================================================================
# VITE
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
